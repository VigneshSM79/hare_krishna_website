# Environment Variables Template
# Copy this file to .env and fill in your actual values

# Supabase Configuration
# These are safe to expose in frontend (public keys)
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ImageKit Configuration
# VITE_ vars are public (safe in the browser).
VITE_IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key_here
VITE_IMAGEKIT_URL_ENDPOINT=your_imagekit_url_endpoint_here

# ImageKit PRIVATE key — SERVER-SIDE ONLY (no VITE_ prefix, never exposed to browser).
# Used by the Vercel serverless function /api/imagekit-list to list gallery images.
# Set this in Vercel → Project → Settings → Environment Variables, and here in
# .env.local if you want to test the gallery locally with `vercel dev`.
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key_here

# Admin Portal Credentials
VITE_ADMIN_EMAIL=your_admin_email_here
VITE_ADMIN_PASSWORD=your_admin_password_here

# Google Apps Script (all forms → Google Sheets — Seva, Weekly Donations, Yearly Donations)
VITE_SEVA_SCRIPT_URL=your_google_apps_script_url_here

# ⚠️ SECURITY NOTE:
# ImageKit PRIVATE KEY is NO LONGER in frontend environment variables!
# It's now securely stored in Supabase Edge Functions.
# See EDGE_FUNCTIONS_GUIDE.md for deployment instructions.

# Instructions:
# 1. Copy this file: cp .env.example .env
# 2. Fill in your actual credentials in the .env file
# 3. NEVER commit the .env file to git
# 4. The .env file is already in .gitignore for protection
# 5. For production (Vercel), set these same variables in Vercel dashboard
